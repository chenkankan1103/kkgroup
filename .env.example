UI_DISCORD_BOT_TOKEN=YOUR_UI_BOT_TOKEN_HERE
SHOP_DISCORD_BOT_TOKEN=YOUR_SHOP_BOT_TOKEN_HERE
DISCORD_SYS_CHANNEL_ID=YOUR_CHANNEL_ID
STAFF_ID_CHANNEL_ID=YOUR_CHANNEL_ID
WELCOME_CHANNEL_ID=YOUR_CHANNEL_ID
PUNISHMENT_CHANNEL_ID=YOUR_CHANNEL_ID
INTRODUCE_CHANNEL_ID=YOUR_CHANNEL_ID
IMAGE_STORAGE_CHANNEL_ID=YOUR_CHANNEL_ID
FORUM_CHANNEL_ID=YOUR_CHANNEL_ID
WORK_CHANNEL_ID=YOUR_CHANNEL_ID
KKCOIN_RANK_CHANNEL_ID=YOUR_CHANNEL_ID
HOSPITAL_CHANNEL_ID=YOUR_CHANNEL_ID
ANNOUNCEMENT_CHANNEL_ID=YOUR_CHANNEL_ID
ANNOUNCEMENT_MESSAGE_ID=YOUR_MESSAGE_ID

# 用戶與角色相關設定
MEMBER_ROLE_ID=YOUR_ROLE_ID
MUTE_ROLE_ID=YOUR_ROLE_ID
TEMP_ROLE1_ID=YOUR_ROLE_ID
TEMP_ROLE2_ID=YOUR_ROLE_ID
INJURED_ROLE_ID=YOUR_ROLE_ID
ROLE_CAR=YOUR_ROLE_ID
ROLE_CHAT_WORKER=YOUR_ROLE_ID
ROLE_TEAM_LEAD=YOUR_ROLE_ID
ROLE_ACCOUNTING=YOUR_ROLE_ID
ROLE_SCAM_ROOM=YOUR_ROLE_ID
ROLE_REGIONAL_DIRECTOR=YOUR_ROLE_ID
RAINBOW_ROLE_ID=YOUR_ROLE_ID
