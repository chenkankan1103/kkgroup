# AI 相關設定 (Google API)
AI_API_KEY=YOUR_GOOGLE_API_KEY_HERE
AI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent
AI_API_MODEL=gemini-2.0-flash
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_API_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
API_TIMEOUT=20
AI_TIMEOUT=10

# 其他 API 服務
GITHUB_TOKEN=YOUR_GITHUB_TOKEN_HERE
HUGGINGFACE_TOKEN=YOUR_HF_TOKEN_HERE
REPLICATE_API_TOKEN=YOUR_REPLICATE_TOKEN_HERE
CWB_API_KEY=YOUR_CWB_API_KEY_HERE

# 服務配置
DISCORD_CLIENT_ID=YOUR_CLIENT_ID
DISCORD_CLIENT_SECRET=YOUR_CLIENT_SECRET
FLASK_SECRET_KEY=YOUR_SECRET_KEY_HERE

# 數據庫或其他連接字符串
DATABASE_URL=YOUR_DB_CONNECTION_STRING

# 注意: 請勿將實際密鑰提交到 Git
